# AgentSync 사용자 컨테이너 이미지
# 빌드:  docker build -f infra/Dockerfile.agent -t agentsync-agent .
# 실행:  docker run -d --name u-<userid> -v u-<userid>-data:/data \
#          -e ANTHROPIC_API_KEY=... -e OPENAI_API_KEY=... \
#          --memory=2g --cpus=2 --security-opt no-new-privileges \
#          -p 127.0.0.1:0:4310 agentsync-agent

FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates tini procps \
  && rm -rf /var/lib/apt/lists/*

# 에이전트 CLI 설치 (API 키 모드로 사용)
RUN npm install -g --no-fund --no-audit \
    @anthropic-ai/claude-code \
    @openai/codex \
    @google/gemini-cli \
    @qwen-code/qwen-code

# 비루트 사용자 + 데이터 볼륨
RUN useradd -m -u 1001 agent && mkdir -p /data && chown agent:agent /data
VOLUME /data

# agentsync 서버 (로컬판 코드 그대로)
WORKDIR /app
COPY server/package.json server/package-lock.json ./
RUN npm ci --no-fund --no-audit
COPY server/src ./src
COPY server/tsconfig.json ./

USER agent
ENV NODE_ENV=production \
    PORT=4310 \
    HOST=0.0.0.0 \
    AGENTSYNC_DATA_DIR=/data/agentsync

EXPOSE 4310
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["npx", "tsx", "src/index.ts"]
